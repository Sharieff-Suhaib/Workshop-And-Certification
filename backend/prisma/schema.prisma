datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  password      String
  role          Role     @default(USER)
  profileImage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  registrations Registration[]
  workshopRegistrations WorkshopRegistration[]
  @@map("users")
}

model Session {
  sid    String   @id
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire])
  @@map("session")
}

enum Role {
  USER
  MODERATOR
  SUPER_ADMIN
}

model Workshop {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("Technical")
  date        DateTime
  time        String
  location    String? 
  capacity    Int?
  createdAt   DateTime @default(now())
  registrations Registration[]
  workshopRegistrations WorkshopRegistration[]
  @@map("workshops")
}

model Registration {
  id              String   @id @default(cuid())
  certificateId   String   @unique
  url             String
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())

  userId          String
  workshopId      String

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop        Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([workshopId])
  @@map("registrations")
}

//npx prisma migrate dev --name add_workshop_registration
model WorkshopRegistration {
  id          String   @id @default(cuid())
  userId      String
  workshopId  String

  fullName    String
  email       String
  phone       String
  college     String
  department  String
  year        String
  experience  String?

  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workshop    Workshop @relation(fields: [workshopId], references: [id], onDelete: Cascade)

  @@unique([userId, workshopId])
  @@index([userId])
  @@index([workshopId])

  @@map("workshop_registrations")
}